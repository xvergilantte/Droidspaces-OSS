(allow droidspacesd init (file (read)))
(allow droidspacesd kernel (file (read)))
(allow droidspacesd kernel (key (link)))
(allow droidspacesd kernel (process (setsched)))
(allow droidspacesd kernel (system (syslog_mod)))
