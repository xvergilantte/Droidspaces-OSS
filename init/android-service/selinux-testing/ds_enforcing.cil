(allow droidspacesd droidspacesd (file (ioctl)))
(allow droidspacesd droidspacesd (netlink_route_socket (bind create getattr nlmsg_read nlmsg_write read setopt write)))
(allow droidspacesd droidspacesd (packet_socket (read)))
(allow droidspacesd droidspacesd (rawip_socket (create getopt setopt write)))
(allow droidspacesd droidspacesd (udp_socket (create ioctl)))
(allow droidspacesd droidspacesd (unix_dgram_socket (ioctl)))
(allow droidspacesd droidspacesd_exec (file (entrypoint execute_no_trans open read)))
(allow droidspacesd droidspacesd_exec (lnk_file (read)))
(allow droidspacesd fs_bpf (dir (search)))
(allow droidspacesd fs_bpf_netd_shared (dir (search)))
(allow droidspacesd fs_bpf_netd_shared (file (read)))
(allow droidspacesd fuse (dir (read)))
(allow droidspacesd fuse (filesystem (unmount)))
(allow droidspacesd fusectlfs (filesystem (remount)))
