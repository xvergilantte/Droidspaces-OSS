; Minimal rules to suppress log spam in dmesg
; It is impossible to make droidspaces an enforcing domain. Fix one denial, and ten more appear, and it continues until the world ends
; This is the best we can do, which is suppressing the visible denials that happen during permissive mode

; droidspacesd
(allow droidspacesd app_data_file (dir (add_name create getattr mounton open read remove_name search setattr write)))
(allow droidspacesd app_data_file (file (append create getattr ioctl open read relabelfrom setattr write)))
(allow droidspacesd app_data_file (lnk_file (unlink)))
(allow droidspacesd app_data_file (sock_file (write)))
(allow droidspacesd binder_device (chr_file (getattr ioctl open read write)))
(allow droidspacesd bpfloader (bpf (prog_run)))
(allow droidspacesd cgroup (dir (create read rmdir setattr)))
(allow droidspacesd cgroup (file (ioctl read)))
(allow droidspacesd cgroup_v2 (dir (add_name create read rmdir search setattr write)))
(allow droidspacesd cgroup_v2 (file (getattr ioctl open read watch write)))
(allow droidspacesd cgroup_v2 (filesystem (remount)))
(allow droidspacesd configfs (filesystem (remount)))
(allow droidspacesd debugfs (filesystem (remount)))
(allow droidspacesd debugfs_tracing_debug (filesystem (remount)))
(allow droidspacesd device (chr_file (getattr ioctl open read write)))
(allow droidspacesd device (dir (add_name write)))
(allow droidspacesd devpts (chr_file (getattr ioctl lock open read setattr write)))
(allow droidspacesd devpts (filesystem (mount)))
(allow droidspacesd dm_device (blk_file (getattr)))
