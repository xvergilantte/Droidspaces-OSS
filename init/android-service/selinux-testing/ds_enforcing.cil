; init
(allow init droidspacesd (process (noatsecure rlimitinh siginh transition)))
(allow init droidspacesd (process2 (nosuid_transition)))
(allow init droidspacesd_exec (file (execute getattr open read)))
(allow init droidspacesd_exec (lnk_file (getattr read)))
(allow init init_boot_block_device (lnk_file (relabelto)))
(allow init system_data_file (file (execute getattr map open read)))

; kernel
(allow kernel device (blk_file (create getattr setattr unlink)))
(allow kernel droidspacesd (fd (use)))
(allow kernel system_data_file (file (getattr open read write)))
(allow kernel vold_data_file (file (getattr open read write)))

; netd
(allow netd proc_net (dir (add_name)))
(allow netd proc_net (file (create)))

