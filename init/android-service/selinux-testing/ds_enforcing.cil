(allow droidspacesd tmpfs (chr_file (getattr ioctl link open read rename unlink write)))
(allow droidspacesd tmpfs (dir (add_name create mounton open read remove_name rename reparent rmdir setattr watch write)))
(allow droidspacesd tmpfs (fifo_file (create getattr open read unlink write)))
