# Droidspaces init service
# Copyright (C) 2026 ravindu644 <droidcasts@protonmail.com>
# SPDX-License-Identifier: GPL-3.0-or-later
#
# Starts the droidspaces daemon in the post-fs-data stage on boot.
# Once boot completes, runs the autoboot script to start any containers
# marked as "Run at boot". If the daemon is killed and respawned by init,
# the autoboot script is triggered again automatically.
#
# Note: if a user manually stopped a container before the daemon was killed,
# the autoboot script will start it again - this is a known edge case, since
# daemon kills are rare in normal usage.

service droidspacesd /vendor/bin/droidspaces daemon --foreground
    user root
    group root
    seclabel u:r:droidspacesd:s0
    onrestart start droidspaces_autoboot

service droidspaces_autoboot /vendor/bin/droidspaces_autoboot.sh
    user root
    group root
    seclabel u:r:droidspacesd:s0
    oneshot
    disabled

on post-fs-data
    start droidspacesd

on property:sys.boot_completed=1
    start droidspaces_autoboot
